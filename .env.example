# WhatIfGPT Environment Variables

# Copy this file to .env and fill in your actual values

# ===========================================
# BACKEND VARIABLES (place .env in root directory)
# ===========================================

# Groq API Key - Get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Backend server port (optional, defaults to 5000)
PORT=5000

# Debug mode for development (optional, True/False)
DEBUG=True

# ===========================================
# FRONTEND VARIABLES (place .env in frontend/ directory)
# ===========================================

# Backend API URL for production builds (optional in dev)
VITE_API_URL=http://localhost:5000

# Custom application title (optional)
VITE_APP_TITLE=WhatIfGPT

# Python version to use for deployment (Render, etc.)
PYTHON_VERSION=3.11.9
